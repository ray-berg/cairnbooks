# ──────────────────────────────────────────────
# CairnBooks – .gitignore
# ──────────────────────────────────────────────

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node / JavaScript / TypeScript
node_modules/
.npm
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
.next/
out/
.nuxt/
.svelte-kit/
dist/
build/
*.tsbuildinfo

# Environment & secrets
.env
.env.local
.env.*.local
*.env
secrets.yaml
secrets.json

# Docker
*.pid

# Terraform / deploy
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraformrc
terraform.rc

# Compiled / binary
*.so
*.dylib
*.dll
*.exe
*.class
*.jar

# Misc
*.bak
*.tmp
