# =============================================================================
# CairnBooks — Backup Configuration
#
# Copy this file to backup.env and fill in your values.
# Never commit backup.env to version control.
# =============================================================================

# --- Application --------------------------------------------------------------

# Absolute path where CairnBooks is deployed
APP_DIR=/opt/cairnbooks

# Docker Compose project name (used to locate containers)
COMPOSE_PROJECT=cairnbooks

# --- PostgreSQL ---------------------------------------------------------------

# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in docker-compose.yml
PG_USER=cairnbooks
PG_PASSWORD=cairnbooks
PG_DB=cairnbooks
# Used only when not running via docker exec (e.g. external Postgres)
PG_HOST=localhost
PG_PORT=5432

# --- Local backup directory ---------------------------------------------------

# Directory on the LXC host where compressed dumps are written before upload
BACKUP_DIR=/var/backups/cairnbooks

# Number of days to retain local backup files
RETAIN_DAYS=7

# --- Local MinIO (within the LXC / docker-compose stack) ---------------------

MINIO_ALIAS=cairnbooks-local
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=cairnbooks
MINIO_SECRET_KEY=cairnbooks_secret
MINIO_BUCKET=cairnbooks-backups

# --- Remote / off-LXC storage (S3-compatible or another MinIO instance) ------
# Leave REMOTE_ENDPOINT empty to skip remote sync entirely.

REMOTE_ALIAS=cairnbooks-remote
REMOTE_ENDPOINT=
REMOTE_ACCESS_KEY=
REMOTE_SECRET_KEY=
REMOTE_BUCKET=cairnbooks-backups

# Set to "true" to fail the whole backup job when remote sync fails.
# Default (false) logs a warning and exits 0 so the local backup isn't lost.
REMOTE_FAIL_FATAL=false
